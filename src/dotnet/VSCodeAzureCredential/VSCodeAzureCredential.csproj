<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>netstandard2.0</TargetFramework>
    <LangVersion>latest</LangVersion>
    <Nullable>enable</Nullable>
    <PackageId>VSCodeAzureCredential</PackageId>
    <Version>0.1.0</Version>
    <Authors>local</Authors>
    <Description>TokenCredential that obtains Azure access tokens from the VS Code "Azure Service Authentication" extension.</Description>
    <PackageTags>azure;identity;vscode;authentication;testing</PackageTags>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <NoWarn>$(NoWarn);CS1591</NoWarn>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="Azure.Identity" Version="1.13.1" />
  </ItemGroup>
</Project>
